#!/bin/bash
# K_E_R secret scanner pre-commit hook.
# 활성화: ln -s ../../.git-hooks/pre-commit .git/hooks/pre-commit
#       또는: cp .git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

VENV_PYTHON="$REPO_ROOT/.venv/bin/python"
PYTHON="${VENV_PYTHON:-python3}"
if [ ! -x "$PYTHON" ]; then
  PYTHON="python3"
fi

echo "[pre-commit] secret scanner 실행..."
if ! "$PYTHON" -m pipeline.security_check; then
  echo ""
  echo "❌ 커밋 차단: secret 의심 패턴 발견."
  echo "   해결 후 다시 commit. 우회 (강력 비추): git commit --no-verify"
  exit 1
fi
echo "[pre-commit] OK"
