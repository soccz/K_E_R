# K_E_R 환경변수 템플릿
# 사용법: 이 파일을 .env로 복사 후 실제 키로 채움
#   cp .env.example .env
#   chmod 600 .env  # 다른 사용자 read 차단
# .env는 .gitignore에 등록되어 있어 절대 commit 안 됨

# DART OpenAPI 인증키 (필수)
# 발급: opendart.fss.or.kr → 인증키 신청
DART_API_KEY=PUT_YOUR_40_CHAR_DART_KEY_HERE

# Anthropic API 키 (옵션 — claude_code provider 사용 시 불필요)
# 사용 케이스: LLM_PROVIDER=anthropic 으로 전환할 때만 필요
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# LLM provider 선택 (기본: claude_code = 구독 인증)
# LLM_PROVIDER=claude_code
# CLAUDE_CODE_MODEL=sonnet

# Validator 재시도 횟수 (기본: 3)
# VALIDATOR_MAX_RETRIES=3
